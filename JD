<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Pham Thanh Loan — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #F5FBFF;
    --bg-secondary: #EDF8FC;
    --white: #FFFFFF;
    --text: #0F2942;
    --text-light: #4B6783;
    --text-muted: #7C95AD;
    --primary: #1EA7C5;
    --primary-dark: #147A96;
    --primary-light: #7ED7E8;
    --border: #DCECF3;
    --font: 'DM Sans', sans-font;
}
  html { scroll-behavior: smooth; }
  body {
  font-family: var(--font);
  background:
    radial-gradient(circle at top right,
      rgba(126,215,232,0.18),
      transparent 30%),
    linear-gradient(
      180deg,
      #F8FDFF 0%,
      #F2FAFD 45%,
      #EDF8FC 100%
    );

  color: var(--text);
  font-size: 15px;
  line-height: 1.8;
  overflow-x: hidden;
}
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.25rem 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(249,246,240,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--rule);
  }
  .nav-logo {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.25s;
  }
  .nav-links a:hover { color: var(--ink); 

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 4rem 5rem;
  }
  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    animation: fadeUp 0.9s ease both;
  }
  .hero-tag {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hero-tag::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }
  h1 {
    font-family: var(--font);
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
  }
  h1 em {
    color: var(--primary);
    font-style: normal;
  }
  .btn-row { display: flex; gap: 1rem; }
  .btn-primary {
  background: linear-gradient(
    135deg,
    #1EA7C5,
    #147A96
  );
  color: white;
  border-radius: 999px;
  padding: .85rem 2rem;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: .1em;
  transition: .3s;
}
.btn-primary:hover {
  transform: translateY(-3px);
}
  .btn-ghost {
    display: inline-block;
    padding: 0.7rem 2rem;
    border: 0.5px solid var(--ink-light);
    color: var(--ink-light);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.25s;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

  hr.divider { border: none; border-top: 0.5px solid var(--rule); margin: 0 4rem; }

  section {
    max-width: 800px;
    margin: 0 auto;
    padding: 6rem 4rem;
  }
  .section-label {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .section-label::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }
  h2 {
    font-family: var(--font);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: 2.5rem;
    letter-spacing: -0.01em;
  }
  h2 em { font-style: italic; color: var(--accent); }

  .about-text p {
    color: var(--ink-light);
    font-size: 15px;
    line-height: 1.9;
    margin-bottom: 1.25rem;
  }
  .about-text p:last-child { margin-bottom: 0; }

  .edu-block {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 0 3rem;
    align-items: start;
    padding: 2rem 0;
    border-top: 0.5px solid var(--rule);
  }
  .edu-block:last-child { border-bottom: 0.5px solid var(--rule); }
  .edu-year {
    font-family: var(--font);
    font-size: 1rem;
    color: var(--ink-muted);
    padding-top: 0.2rem;
    font-style: italic;
  }
  .edu-title {
    font-family: var(--font);
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 0.3rem;
  }
  .edu-school {
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .skills-stack { 
    display: flex; 
    flex-direction: column; 
    gap: 2rem; 
  }
  
  .skill-group {
    padding: 1.8rem 2rem;
    background: rgba(255,255,255,0.85);
  
    border: 1px solid rgba(30,167,197,0.12);
  
    border-radius: 20px;
  
    backdrop-filter: blur(10px);
  
    transition: all 0.3s ease;
  }
  
  .skill-group:hover {
    transform: translateY(-4px);
  
    box-shadow:
      0 10px 30px rgba(30,167,197,0.08);
  }
  
  .skill-group-title {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 600;
  }
  
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  
  .skill-tag {
    font-size: 13px;
    padding: 0.45rem 1rem;
  
    border: 1px solid #DCECF3;
  
    color: var(--text-light);
  
    border-radius: 999px;
  
    background: #F8FCFE;
  
    transition: all 0.25s ease;
  }
  
  .skill-tag:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  
  .skill-tag.feat {
    background:
      linear-gradient(
        135deg,
        #1EA7C5,
        #147A96
      );
  
    color: white;
  
    border: none;
  }
  .contact-list { display: flex; flex-direction: column; gap: 1rem; }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 0.5px solid var(--rule);
    background: var(--warm-white);
    border-radius: 2px;
    text-decoration: none;
    color: var(--ink);
    transition: all 0.25s;
  }
  .contact-item:hover { border-color: var(--accent); transform: translateX(4px); }
  .contact-label {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 2px;
  }
  .contact-value { font-family: var(--font); font-size: 1.05rem; }

  footer {
    text-align: center;
    padding: 2.5rem 4rem;
    border-top: 0.5px solid var(--rule);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(255,255,255,.75);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 4px 20px rgba(0,0,0,.03);
    padding: 1.25rem 4rem;
  }
    .nav-links { gap: 1.25rem; }
    .hero { padding: 7rem 1.5rem 4rem; }
    section { padding: 4rem 1.5rem; }
    hr.divider { margin: 0 1.5rem; }
    .edu-block { grid-template-columns: 1fr; gap: 0.4rem; }
  }
</style>
</head>
<body>

