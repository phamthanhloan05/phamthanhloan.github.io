<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HEINEKEN Vietnam – Hanoi Brewery · Waste & Co-product Report 2025</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --g:#1D9E75;--gL:#EAF3DE;--gD:#085041;--gM:#5DCAA5;
    --b:#378ADD;--bL:#E6F1FB;--bD:#0C447C;
    --a:#BA7517;--aL:#FAEEDA;--am:#EF9F27;
    --r:#E24B4A;--rL:#FCEBEB;
    --p:#7F77DD;--pL:#EEEDFE;
    --o:#D85A30;--oL:#FAEAE1;
    --gr:#888780;--grL:#F1EFE8;--grD:#444441;
    --t:#1C1C1A;--tm:#5F5E5A;--tl:#888780;
    --bd:#D3D1C7;--bg:#F8F7F4;--w:#fff;
    --rad:12px;--rads:8px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--t);font-size:14px;line-height:1.6}
  .page{max-width:1160px;margin:0 auto;padding:32px 24px 80px}

  /* HEADER */
  .hdr{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap;margin-bottom:32px;padding-bottom:20px;border-bottom:2px solid var(--bd)}
  .hdr-left{}
  .badge-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
  .badge{background:var(--g);color:#fff;font-size:11px;font-weight:700;letter-spacing:1px;padding:3px 10px;border-radius:20px;text-transform:uppercase}
  .badge-sub{color:var(--tm);font-size:12px}
  .hdr h1{font-size:22px;font-weight:700;margin-bottom:3px}
  .hdr .sub{font-size:13px;color:var(--tm)}
  .btn{background:var(--g);color:#fff;border:none;padding:10px 20px;border-radius:var(--rads);font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;white-space:nowrap;transition:background .2s;text-decoration:none}
  .btn:hover{background:var(--gD)}
  .btn svg{width:16px;height:16px;flex-shrink:0}

  /* SECTION LABEL */
  .sec{font-size:11px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:var(--tl);margin:40px 0 14px;display:flex;align-items:center;gap:10px}
  .sec::after{content:'';flex:1;height:1px;background:var(--bd)}

  /* GRIDS */
  .g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
  .g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
  .full{grid-column:1/-1}

  /* CARD */
  .card{background:var(--w);border:1px solid var(--bd);border-radius:var(--rad);padding:20px}
  .card h3{font-size:14px;font-weight:600;margin-bottom:3px}
  .card .csub{font-size:12px;color:var(--tm);margin-bottom:14px}
  .cw{position:relative;width:100%}

  /* KPI */
  .kpi{background:var(--w);border:1px solid var(--bd);border-radius:var(--rad);padding:16px 18px}
  .kpi .lbl{font-size:12px;color:var(--tm);margin-bottom:5px}
  .kpi .val{font-size:22px;font-weight:700;line-height:1.1}
  .kpi .note{font-size:11px;color:var(--tl);margin-top:4px}
  .kpi.g .val{color:var(--gD)} .kpi.a .val{color:var(--a)} .kpi.r .val{color:var(--r)}
  .kpi.b .val{color:var(--bD)} .kpi.p .val{color:var(--p)} .kpi.o .val{color:var(--o)}

  /* LEGEND */
  .leg{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:12px;font-size:12px;color:var(--tm)}
  .leg span{display:flex;align-items:center;gap:5px}
  .ld{width:10px;height:10px;border-radius:2px;display:inline-block;flex-shrink:0}

  /* PILLS */
  .pills{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
  .pill{font-size:11px;font-weight:500;padding:4px 10px;border-radius:20px}
  .pg{background:var(--gL);color:var(--gD)} .pa{background:var(--aL);color:var(--a)}
  .pr{background:var(--rL);color:var(--r)} .pb{background:var(--bL);color:var(--bD)}
  .pp{background:var(--pL);color:var(--p)} .pgr{background:var(--grL);color:var(--grD)}
  .po{background:var(--oL);color:var(--o)}

  /* INSIGHT BOX */
  .ibox{background:var(--gL);border-left:3px solid var(--g);border-radius:0 var(--rads) var(--rads) 0;padding:12px 14px;font-size:13px;color:var(--gD);margin-top:12px;line-height:1.5}
  .ibox.amber{background:var(--aL);border-color:var(--am);color:var(--a)}
  .ibox.red{background:var(--rL);border-color:var(--r);color:var(--r)}
  .ibox.blue{background:var(--bL);border-color:var(--b);color:var(--bD)}

  /* RECOMMENDATIONS TABLE */
  .rec-tbl{width:100%;border-collapse:collapse;font-size:13px;margin-top:10px}
  .rec-tbl th{background:var(--bg);padding:9px 12px;text-align:left;font-size:11px;font-weight:700;letter-spacing:.5px;color:var(--tm);border-bottom:2px solid var(--bd);text-transform:uppercase}
  .rec-tbl td{padding:10px 12px;border-bottom:1px solid var(--bd);vertical-align:top;line-height:1.5}
  .rec-tbl tr:last-child td{border-bottom:none}
  .rec-tbl tr:hover td{background:var(--bg)}
  .rec-tbl .finding{font-size:12px;color:var(--tm)}
  .bge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:600}
  .bgg{background:var(--gL);color:var(--gD)} .bga{background:var(--aL);color:var(--a)}
  .bgr{background:var(--rL);color:var(--r)} .bgb{background:var(--bL);color:var(--bD)}
  .bgp{background:var(--pL);color:var(--p)}

  /* SECTION DIVIDER */
  .sdiv{background:var(--bg);border:1px solid var(--bd);border-radius:var(--rads);padding:10px 16px;margin-top:12px;font-size:12px;color:var(--tm);display:flex;align-items:center;gap:8px}
  .sdiv strong{color:var(--t)}

  /* FOOTER */
  .ftr{margin-top:60px;padding-top:18px;border-top:1px solid var(--bd);font-size:12px;color:var(--tl);display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}

  @media(max-width:720px){.g2,.g3,.g4{grid-template-columns:1fr}.full{grid-column:auto}}
  @media print{body{background:#fff}.btn{display:none}.page{padding:16px}}
</style>
</head>
<body>
